rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-100 chars)
    //   - content: string (required, 1-10000 chars)
    //   - category: string (required, enum: ['PDV', 'Financeiro', 'Estoque', 'Relatórios', 'Geral'])
    //   - authorId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorId) {
      return isAuthenticated() && request.auth.uid == authorId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "tonfoxmartins@gmail.com");
    }

    function isValidArticle(data) {
      let validCategories = ['PDV', 'Financeiro', 'Estoque', 'Relatórios', 'Geral'];
      return data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 20000 &&
             data.category in validCategories &&
             data.updatedAt is timestamp;
    }

    match /articles/{articleId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.authorId == request.auth.uid));
      allow create: if isAuthenticated() && 
                      isValidArticle(request.resource.data) && 
                      request.resource.data.authorId == request.auth.uid &&
                      request.resource.data.createdAt is timestamp;
      allow update: if isAuthenticated() && 
                      (isAdmin() || (resource != null && resource.data.authorId == request.auth.uid)) &&
                      isValidArticle(request.resource.data) &&
                      (isAdmin() || (
                        request.resource.data.authorId == resource.data.authorId &&
                        request.resource.data.createdAt == resource.data.createdAt
                      ));
      allow delete: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.authorId == request.auth.uid));
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (isAdmin() || (resource == null || resource.data.userId == request.auth.uid));
    }

    match /sales/{saleId} {
      allow read: if isAuthenticated() && (isAdmin() || (resource != null && 'userId' in resource.data && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
